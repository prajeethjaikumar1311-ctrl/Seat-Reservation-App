# Simple Seat Reservation System

# Create seats (10 seats)
seats = ["Available"] * 10

def show_seats():
    print("\nSeat Status:")
    for i in range(len(seats)):
        print(f"Seat {i+1}: {seats[i]}")

def book_seat():
    show_seats()
    seat = int(input("Enter seat number to book: "))
    
    if seat < 1 or seat > 10:
        print("Invalid seat number!")
    elif seats[seat-1] == "Booked":
        print("Seat already booked!")
    else:
        seats[seat-1] = "Booked"
        print("Seat booked successfully!")

def cancel_booking():
    show_seats()
    seat = int(input("Enter seat number to cancel: "))
    
    if seat < 1 or seat > 10:
        print("Invalid seat number!")
    elif seats[seat-1] == "Available":
        print("Seat is not booked yet!")
    else:
        seats[seat-1] = "Available"
        print("Booking cancelled!")

while True:
    print("\n---- Seat Reservation App ----")
    print("1. View Seats")
    print("2. Book Seat")
    print("3. Cancel Booking")
    print("4. Exit")
    
    choice = input("Enter choice: ")

    if choice == "1":
        show_seats()
    elif choice == "2":
        book_seat()
    elif choice == "3":
        cancel_booking()
    elif choice == "4":
        print("Thank you for using the system!")
        break
    else:
        print("Invalid choice. Try again.")
